<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zinc_900">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:textColor="@color/zinc_400"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Submission Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUBMISSION EMAIL"
            android:textColor="@color/amber_500"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:boxStrokeColor="@color/zinc_600"
            app:hintTextColor="@color/zinc_400"
            app:boxBackgroundColor="@color/zinc_800">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:textColor="@color/white"
                android:textColorHint="@color/zinc_400"
                android:hint="Email address" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Scroll Speed -->
        <TextView
            android:id="@+id/speedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SCROLL SPEED: 3"
            android:textColor="@color/amber_500"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Slow"
                android:textColor="@color/zinc_400"
                android:textSize="12sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/speedSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="9"
                android:progress="2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fast"
                android:textColor="@color/zinc_400"
                android:textSize="12sp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Font Size -->
        <TextView
            android:id="@+id/fontSizeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FONT SIZE: 22"
            android:textColor="@color/amber_500"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A"
                android:textColor="@color/zinc_400"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/fontSizeSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="20"
                android:progress="6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A"
                android:textColor="@color/zinc_400"
                android:textSize="22sp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Text Theme -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TEXT THEME"
            android:textColor="@color/amber_500"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchBlackOnWhite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Black on White"
            android:textColor="@color/zinc_200"
            android:textSize="14sp"
            android:layout_marginBottom="28dp" />

        <!-- Teleprompter Position -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TELEPROMPTER POSITION"
            android:textColor="@color/amber_500"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchPromptTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Show above camera"
            android:textColor="@color/zinc_200"
            android:textSize="14sp"
            android:layout_marginBottom="28dp" />

        <!-- Script -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUDITION SCRIPT"
            android:textColor="@color/amber_500"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLoadFile"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Load from .txt File"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"
            app:backgroundTint="@color/zinc_700"
            app:cornerRadius="8dp"
            app:strokeColor="@color/zinc_600"
            app:strokeWidth="1dp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:boxStrokeColor="@color/zinc_600"
            app:hintTextColor="@color/zinc_400"
            app:boxBackgroundColor="@color/zinc_800">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/scriptInput"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:gravity="top|start"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"
                android:textColor="@color/white"
                android:textColorHint="@color/zinc_400"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.4"
                android:hint="Paste script here or load from a .txt file…" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Settings"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="15sp"
            app:backgroundTint="@color/amber_600"
            app:cornerRadius="8dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
