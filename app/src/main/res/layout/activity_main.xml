<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/zinc_900">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/black"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.12"
            android:text="SELF-TAPE"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- CUT — visible during recording -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginEnd="8dp"
            android:text="CUT"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="@color/zinc_700"
            app:cornerRadius="6dp"
            app:strokeColor="@color/zinc_600"
            app:strokeWidth="1dp" />

        <!-- Retake — visible during review -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRetake"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginEnd="6dp"
            android:text="Retake"
            android:textColor="@color/zinc_300"
            android:textSize="12sp"
            android:visibility="gone"
            app:backgroundTint="@color/zinc_700"
            app:cornerRadius="6dp"
            app:strokeColor="@color/zinc_600"
            app:strokeWidth="1dp" />

        <!-- Submit Tape — visible during review -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:layout_marginEnd="8dp"
            android:text="Submit Tape"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:backgroundTint="@color/amber_600"
            app:cornerRadius="6dp" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:contentDescription="Settings" />

    </LinearLayout>

    <!-- ── Camera Viewport (3:4 aspect ratio) ────────────────────────────── -->
    <FrameLayout
        android:id="@+id/viewportContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/black"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter" />

        <com.tekphreak.sizzlr.FaceGuideView
            android:id="@+id/faceGuide"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Countdown overlay -->
        <TextView
            android:id="@+id/countdownText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:textSize="140sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="#CC000000"
            android:visibility="gone" />

        <!-- REC / ON AIR indicator -->
        <LinearLayout
            android:id="@+id/recIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@drawable/rec_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:visibility="gone">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle_red_pulse" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:letterSpacing="0.15"
                android:text="ON AIR"
                android:textColor="#EF4444"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="monospace"
                android:text="00:00"
                android:textColor="@color/white"
                android:textSize="11sp" />
        </LinearLayout>

    </FrameLayout>

    <!--
        Teleprompter ScrollView is a direct ConstraintLayout child — NOT inside
        the NestedScrollView — so it gets a proper bounded height and the
        ValueAnimator scroll works correctly.
    -->
    <ScrollView
        android:id="@+id/teleprompterScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/zinc_900"
        android:scrollbars="none"
        android:overScrollMode="never"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/viewportContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/teleprompterText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:lineSpacingMultiplier="1.6"
            android:textColor="@color/zinc_200"
            android:textSize="22sp" />

    </ScrollView>

    <!-- ── Controls panel (idle / review / success) ──────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/controlsScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewportContainer">

        <LinearLayout
            android:id="@+id/controlsInner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/zinc_800"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Audition script display -->
            <FrameLayout
                android:id="@+id/scriptBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/script_box_bg"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.4"
                    android:padding="20dp"
                    android:paddingTop="28dp"
                    android:text="&quot;Hi, my name is Michael, and I am reading for the role of the Lead Detective.&quot;"
                    android:textColor="@color/zinc_200"
                    android:textSize="17sp"
                    android:textStyle="italic" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|center_horizontal"
                    android:layout_marginTop="-1dp"
                    android:background="@color/amber_500"
                    android:letterSpacing="0.1"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:text="AUDITION SCRIPT"
                    android:textColor="@color/black"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- ACTION (Record) button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="10dp"
                android:enabled="false"
                android:text="ACTION  (Record)"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@color/red_700"
                app:cornerRadius="8dp"
                app:iconGravity="textStart"
                app:iconPadding="10dp" />

            <!-- Success card -->
            <LinearLayout
                android:id="@+id/successMsg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/success_bg"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone">

                <View
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/circle_green_filled" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Tape Submitted"
                    android:textColor="#4ADE80"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="Your audition has been saved to your gallery."
                    android:textColor="@color/zinc_400"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNewClip"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginTop="16dp"
                    android:text="Record Another Clip"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    app:backgroundTint="@color/zinc_700"
                    app:cornerRadius="20dp"
                    app:strokeColor="@color/zinc_600"
                    app:strokeWidth="1dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
